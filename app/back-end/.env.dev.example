# Django settings
SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,back-end
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_AUTH_COOKIE_SAMESITE=Lax  # SameSite=None requires Secure=True
DJANGO_AUTH_COOKIE_SECURE=False  # Secure=True requires https

# Database settings: PostgreSQL
DB_NAME=your_db
DB_USER=your_user
DB_PW=your_password
# for local development:
DB_HOST=localhost 
# for `docker compose`:
# DB_HOST=db # the name of the postgres database service/container
DB_PORT=5432  # default PostgreSQL port (used in Docker too)
POSTGRES_PW=none  # we shall use one for production

# Django test users
ADMIN_USER=your_admin
ADMIN_EMAIL=your_admin@example.com
ADMIN_PW=your_admin_password

STAFF_USER=staff_user
STAFF_EMAIL=staff_user@example.com
STAFF_PW=staff_user_password

TEST_USER=some_user
TEST_EMAIL=some_user@example.com
TEST_PW=some_user_password

TEST_USER2=another_user
TEST_EMAIL2=another_user@example.com
TEST_PW2=another_user_password
