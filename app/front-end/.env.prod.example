# ─── Environment Variables ───────────────────────────────────
# Vite exposes only variables prefixed with VITE_ to client code.
# Never put secrets here — this file is committed to Git as a template.
#
# Copy this file to .env.local for local overrides (gitignored by default).
# ─────────────────────────────────────────────────────────────

VITE_APP_TITLE=animize_eat

# Base URL for API requests.
# - Development: http://localhost:8000 (direct to Django dev server)
# - Production:  "" (empty string: same-origin via Nginx reverse proxy)
VITE_API_BASE_URL=""
