# =============================================================================
# Back-end production environment variables
# =============================================================================
# Copy this file to `.env.prod` and fill in real values.
# NEVER commit `.env.prod` to version control.
# =============================================================================

# --- Django ---
SECRET_KEY=generate-a-long-random-secret-key-here
DJANGO_DEBUG=False
DJANGO_ENV=prod

# Comma-separated list of hosts that Django will accept requests from.
# "back-end" is the Docker Compose service name (used by Nginx internally).
# Add your domain name when deploying to a real server.
DJANGO_ALLOWED_HOSTS=localhost,back-end

# CORS: origins allowed to make cross-origin requests.
# In production behind Nginx, the browser sees the same origin, so this
# should match the public URL.
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost

# Cookie security: set to True when using HTTPS.
DJANGO_AUTH_COOKIE_SECURE=False
# SameSite=Lax is fine when front-end and API share the same origin.
DJANGO_AUTH_COOKIE_SAMESITE=Lax

# --- Database (must match the Postgres container config) ---
DB_NAME=animize_eat_prod
DB_USER=animize_eat_user
DB_PW=change-me-to-a-strong-password
# "db" is the Docker Compose service name for PostgreSQL.
DB_HOST=db
DB_PORT=5432

# --- Initial users (used by seed scripts) ---
ADMIN_USER=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PW=your_admin_password

STAFF_USER=staff
STAFF_EMAIL=staff@example.com
STAFF_PW=staff_user_password

TEST_USER=user1
TEST_EMAIL=user1@example.com
TEST_PW=some_user_password

TEST_USER2=user2
TEST_EMAIL2=user2@example.com
TEST_PW2=another_user_password
